# CinemaxParadiso Environment Configuration
# Copy this file to .env and fill in your actual API keys

# TMDB (The Movie Database) API Key
# Get your free API key from: https://www.themoviedb.org/settings/api
# This is required for the app to function
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# OMDB (Open Movie Database) API Key
# Get your free API key from: http://www.omdbapi.com/apikey.aspx
# This is optional but provides additional movie ratings and details
VITE_OMDB_API_KEY=your_omdb_api_key_here

# API Base URLs (usually don't need to change these)
TMDB_BASE_URL=https://api.themoviedb.org/3
OMDB_BASE_URL=http://www.omdbapi.com
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
